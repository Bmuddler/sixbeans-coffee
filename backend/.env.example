# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sixbeans

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173

# Square API
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic Claude
ANTHROPIC_API_KEY=

# GoDaddy (legacy — there is no public merchant API; ingestion is done via
# the Playwright scraper below. Left in place for backward compatibility.)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ---------------------------------------------------------------------------
# Analytics ingestion (added by feat/analytics-ingestion)
# ---------------------------------------------------------------------------

# TapMango loyalty/orders API (used for customer + loyalty analytics pulls)
# Base URL per https://developer.tapmango.com/api-reference/
# Auth header format: "Authentication: ApiKey: <TAPMANGO_API_KEY>"
TAPMANGO_API_KEY=
TAPMANGO_API_BASE_URL=https://openapi.tapmango.com/api/v1

# Encryption key for GoDaddy + TapMango scraper session cookies stored in DB.
# Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SCRAPER_SESSION_ENCRYPTION_KEY=

# Gmail OAuth — used to watch blend556@gmail.com for the DoorDash
# weekly scheduled reports. One-time consent flow from the admin page.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:5173/portal/admin/oauth/callback/gmail

# Sender identity the DoorDash report will be sent from (used for filtering)
DOORDASH_REPORT_FROM_EMAIL=no-reply@doordash.com
DOORDASH_REPORT_INBOX=blend556@gmail.com
