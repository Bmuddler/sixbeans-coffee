# Database
DATABASE_URL=sqlite+aiosqlite:///./sixbeans.db

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Square API (sales data)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic Claude (payroll validation)
ANTHROPIC_API_KEY=

# GoDaddy (cash drawer expected amounts)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ADP (payroll export)
ADP_CLIENT_ID=
ADP_CLIENT_SECRET=

# Frontend
VITE_API_URL=http://localhost:8000
