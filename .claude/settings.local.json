{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",

      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(file:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git restore --staged:*)",

      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",

      "Bash(npm install)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",

      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(python -m mypy:*)",
      "Bash(pip install -r requirements.txt)",

      "Edit",
      "Write",
      "MultiEdit"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git rebase -i:*)",
      "Bash(git commit --amend:*)",

      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",

      "Bash(psql:*)",
      "Bash(pg_restore:*)",

      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",

      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  }
}
